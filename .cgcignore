# CodeGraphContext ignore patterns for The Slippery Slope team repo.
# Synced from `.gitignore` 2026-05-06 for indexing — heavy artifacts, agent
# state, virtualenvs, generated outputs, and binary media stay out of graph.

# Python build / cache
__pycache__/
*.pyc
*.pyo
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
target/
out/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.tox/
coverage/
.next/

# Virtual envs
venv/
.venv/
.venv*/
env/
.env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints
*.ipynb

# ML artifacts (heavy / generated)
checkpoints/
data/shell_game_v2/*.jsonl
data/shell_game_v2/*.metadata.json
outputs/
wandb/
runs/
*.pt
*.pth
*.safetensors
*.bin

# HF cache
.cache/

# Editors / OS
.idea/
.vscode/
*.swp
.DS_Store

# Agent sessions / worktrees / per-repo CLAUDE.md
.agent-sessions/
.claude/
.codex/
claude-worktrees/
codex-worktrees/
CLAUDE.md

# Cross-agent review prompts (local only)
review/

# Env files
.env
.env.local

# Binary / media
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.mp4
*.mp3
*.pptx
*.pdf
*.zip
*.tar
*.gz
*.bz2
*.xz
*.zst
*.7z
*.rar
*.log
*.sqlite*

# Drafts + archive: out-of-graph by intent
deliverables/drafts/
deliverables/archive/
deliverables/evidence/
docs/archive/

# Examples + sample fixtures (not source-of-interest for graph queries)
examples/

# Repo-local symlinks that resolve outside this repository
git-status.sh
.githooks/

# Misc
node_modules/
.git/

